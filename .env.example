# Copy to .env.local (or .env). Never commit real secrets.

# --- tel-backend (required) ---
# Full origin only (no /api path). BFF proxies here: `${TEL_API_URL}/api/v1/...`.
# Example production: https://api.indiatellama.com
TEL_API_URL=http://localhost:4000

# Same origin as tel-backend so /uploads/… preview URLs work in the browser.
# You can use either NEXT_PUBLIC_TEL_API_URL or NEXT_PUBLIC_API_URL (same value as TEL_API_URL).
NEXT_PUBLIC_TEL_API_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000

# MUST equal tel-backend JWT_ACCESS_SECRET (same characters, no extra spaces; simplest: no quotes).
# tel-backend signs access tokens; tel-admin verifies cookies (middleware + API routes).
# If they differ (or one is empty), login can return 200 but session checks fail.
# Fix: copy from tel-backend/.env, restart BOTH servers.
JWT_ACCESS_SECRET=
